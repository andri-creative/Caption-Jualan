@baseUrl = https://openrouter.ai/api/v1
@apiKey = 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

### Get All Models
GET {{baseUrl}}/models
Authorization: Bearer {{apiKey}}

### Get Only Text Models
GET {{baseUrl}}/models?output_modalities=text
Authorization: Bearer {{apiKey}}

### Get Only Image Models
GET {{baseUrl}}/models?output_modalities=image
Authorization: Bearer {{apiKey}}

###

### Chat Completion (Test Gemini)
POST {{baseUrl}}/chat/completions
Authorization: Bearer {{apiKey}}
Content-Type: application/json

{
  "model": "google/gemini-2.0-flash-001",
  "messages": [
    {
      "role": "user",
      "content": "Halo, ini adalah tes koneksi API OpenRouter."
    }
  ]
}

### Chat Completion (NVIDIA Nemotron Free)
POST {{baseUrl}}/chat/completions
Authorization: Bearer {{apiKey}}
Content-Type: application/json

{
  "model": "nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free",
  "messages": [
    {
      "role": "user",
      "content": "Jelaskan apa itu AI reasoning dalam bahasa Indonesia yang sederhana."
    }
  ]
}



#### AUTHENTICATION TEST ####
@url=http://localhost:3000

### 1. Register Akun Baru (Email)
POST {{url}}/api/auth/register
Content-Type: application/json

{
  "email": "testuser@example.com",
  "password": "password123",
  "name": "User Test"
}

### 2. Login (Email)
POST {{url}}/api/auth/login
Content-Type: application/json

{
  "email": "testuser@example.com",
  "password": "password123"
}

### 3. Cek Profil Saya (Butuh Login/Cookie)
GET {{url}}/api/auth/me

### 4. Dapatkan URL Login Google
GET {{url}}/api/auth/google

### 5. Logout
POST {{url}}/api/auth/logout


#### CAPTIONS TEST ####
### 1. Generate Caption (Harus Login Dulu)
POST {{url}}/api/captions/generate
Content-Type: application/json

{
  "product_name": "Sepatu Lari Ultralight",
  "input_prompt": "Buatkan caption untuk Instagram yang santai tapi bikin orang mau beli",
  "model_used": "google/gemini-2.0-flash-001"
}

